{
  // FG-QiMen 的 VSCode 任务配置 / VSCode tasks for FG-QiMen
  //
  // 任务分三层，方便逐步对比:
  //   Layer 1:  原生构建 (plain go build, 无混淆无加固)
  //   Layer 2: 🎭 仅混淆 (garble -literals, 无 UPX 无去特征)
  //   Layer 3: ️ 全流程 (garble + UPX + 去特征 + 签名克隆)
  //
  // 另有  各阶段独立任务 和 🔬 一键对比任务。
  //
  // 任务命名约定 / Task naming convention:
  //   "<emoji> 中文名 / English name"
  //
  //   🔨 构建 (Build)       ⚙️ 质量 (Quality)   🚀 运行 (Run)
  //   🧪 测试 (Test)         🧹 清理 (Clean)     ℹ️ 信息 (Info)
  //   📦 发布 (Release)      🐞 调试 (Debug)
  //   🎭 混淆 (Obfuscate)    🛡️ 加固 (Harden)
  //   📊 阶段 (Stage)        🔬 对比 (Compare)

  "version": "2.0.0",

  "options": {
    "env": {
      "CGO_ENABLED": "0",
      "GOFLAGS": "-trimpath",
      "PATH": "${env:PATH};C:/Program_CodeEnv/just;C:/Program_CodeEnv/GO/bin;C:/Program_Tools/PackersOrUnpackers/upx-5.2.0-win64"
    },
    "shell": {
      "executable": "C:/Program Files/Git/bin/bash.exe",
      "args": ["-lc"]
    }
  },

  "inputs": [
    {
      "id": "goPackage",
      "type": "promptString",
      "description": "Go 包路径(默认 ./...)/ Go package path (e.g. ./cmd, ./internal/tui, ./...)",
      "default": "./..."
    },
    {
      "id": "runArgs",
      "type": "promptString",
      "description": "fg-qimen 启动参数 / Arguments passed to fg-qimen",
      "default": "-H 127.0.0.1 --ports 22,80,3306 -t 5 --shutdown-timeout 2s"
    },
    {
      "id": "buildVersion",
      "type": "promptString",
      "description": "注入的版本号(默认 0.2.0,与 internal/version.Value 一致)/ Version string baked into the binary",
      "default": "0.2.0"
    },
    {
      "id": "testFilter",
      "type": "promptString",
      "description": "go test -run 正则 / go test -run filter (regex)",
      "default": ""
    },
    {
      "id": "garbleSeed",
      "type": "promptString",
      "description": "garble -seed 值（random = 每次随机;base64 字符串 = 固定可复现)/ garble -seed value (random or base64)",
      "default": "o9WDTZ4CN4w="
    },
    {
      "id": "cloneSource",
      "type": "promptString",
      "description": "合法 PE 文件路径(用于证书克隆)/ Path to legitimate PE for signature cloning",
      "default": "C:/Windows/System32/notepad.exe"
    }
  ],

  "tasks": [

    /* ═══════════════════════════════════════════════════════════
       Layer 1: 🔨 原生构建 / Native Build
       plain go build — 无混淆、无加固，用于基线对比
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "🔨 原生 go build (无 strip)/ Native: go build (no strip)",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "${workspaceFolder}/release/fg-qimen-native.exe", "."],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 1: 裸 go build，无 -ldflags strip，无 garble。基线体积最大。Baseline — largest binary."
    },

    {
      "label": "🔨 原生 go build (-s -w strip)/ Native: go build (stripped)",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-ldflags", "-s -w -buildid= -X github.com/LCUstinian/FG-QiMen/internal/version.Value=${input:buildVersion}",
        "-trimpath", "-buildvcs=false",
        "-o", "${workspaceFolder}/release/fg-qimen-native-stripped.exe",
        "."
      ],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 1: go build + -ldflags=-s -w 剥离调试信息。比裸 build 小 20-30%。Stripped debug info."
    },

    {
      "label": "🔨 原生 go build (完整 ldflags)/ Native: go build (full ldflags)",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-ldflags", "-s -w -buildid= -X github.com/LCUstinian/FG-QiMen/internal/version.Value=${input:buildVersion}",
        "-trimpath", "-buildvcs=false",
        "-o", "${workspaceFolder}/release/fg-qimen-native-full.exe",
        "."
      ],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 1: 完整 ldflags + trimpath + buildvcs=false，无 garble。用于 CI 对照。Full ldflags, no garble."
    },

    /* ═══════════════════════════════════════════════════════════
       Layer 2: 🎭 仅混淆 / Obfuscation Only
       garble -literals -seed=random — 无 UPX 无去特征
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "🎭 混淆 当前平台 / Obfuscate: current platform",
      "type": "shell",
      "command": "just",
      "args": ["build"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 2: garble -seed=random -literals build。产物在 release/fg-qimen.exe。SHA256 每次不同。"
    },

    {
      "label": "🎭 混淆 全平台交叉编译 / Obfuscate: all platforms",
      "type": "shell",
      "command": "just",
      "args": ["all"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 2: garble 混淆交叉编译到 5 平台，产物在 release/。"
    },

    {
      "label": "🎭 混淆 固定 seed 可复现 / Obfuscate: fixed seed (reproducible)",
      "type": "shell",
      "command": "just",
      "args": ["garble_seed=${input:garbleSeed}", "build"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 2: 固定 seed 构建可复现二进制。同一 seed 多次构建产出相同 SHA256。"
    },

    {
      "label": "🎭 混淆 纯净构建(不混淆)/ Obfuscate: plain build (no garble)",
      "type": "shell",
      "command": "just",
      "args": ["use_garble=0", "build"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 2 bypass: 绕过 garble，纯净 go build — 用于 dlv 符号解析。"
    },

    {
      "label": " 混淆 查看 garble 信息 / Obfuscate: info",
      "type": "shell",
      "command": "just",
      "args": ["obfuscate-info"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "显示 garble 版本与当前生效的 seed。"
    },

    /* ═══════════════════════════════════════════════════════════
       Layer 3: 🛡️ 全流程 / Full Pipeline
       garble + UPX + 去特征 + (可选)签名克隆
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "🛡️ 全流程 PowerShell / Full pipeline (PowerShell)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/harden.ps1",
        "release/fg-qimen-full.exe",
        "${input:buildVersion}"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 3: 完整加固管线 → release/fg-qimen-full.exe。Garble + UPX --best --lzma + strip_upx.py + (可选)osslsigncode。"
    },

    {
      "label": "🛡️ 全流程 CMD / Full pipeline (CMD)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "${workspaceFolder}\\scripts\\harden.bat",
        "release\\fg-qimen-full.exe",
        "${input:buildVersion}"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 3: 完整加固管线 (CMD 原生) → release/fg-qimen-full.exe。"
    },

    {
      "label": "📦 发布 just release / Release: just release",
      "type": "shell",
      "command": "just",
      "args": ["release"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 3: just release = just build(garble) + just harden(UPX+strip)。产物在 release/fg-qimen.exe。"
    },

    {
      "label": "📦 发布 just release-all / Release: just release-all",
      "type": "shell",
      "command": "just",
      "args": ["release-all"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 3: just release-all = just all(5 平台 garble) + 逐文件 harden。"
    },

    {
      "label": "️ 全流程 带证书克隆 / Full pipeline + cert clone",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-Command",
        "$env:CLONE_SOURCE = '${input:cloneSource}'; & '${workspaceFolder}/scripts/harden.ps1' 'release/fg-qimen-full.exe' '${input:buildVersion}'"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "Layer 3 + 证书克隆: 全流程加固 + osslsigncode 克隆合法 PE 签名。仅限授权测试。"
    },

    /* ═══════════════════════════════════════════════════════════
        各阶段独立 / Individual Pipeline Stages
       单独跑管线的某一阶段，用于调试和对比
       ══════════════════════════════════════════════════════════ */

    {
      "label": "📊 UPX 压缩 / Stage: UPX compress only",
      "type": "shell",
      "command": "upx",
      "args": ["--best", "--lzma", "-q", "${workspaceFolder}/release/fg-qimen.exe"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "📊 仅 UPX 压缩，不跑特征消除。用于观察 UPX 单独的效果。"
    },

    {
      "label": " 去 UPX 特征 / Stage: strip UPX signatures only",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/strip_upx.py", "${workspaceFolder}/release/fg-qimen.exe"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "📊 仅去 UPX 特征(UPX0/UPX1/UPX! → ____)，不压缩。"
    },

    {
      "label": "📊 去特征 dry-run / Stage: strip dry-run (no changes)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/strip_upx.py", "${workspaceFolder}/release/fg-qimen.exe", "--dry-run"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "📊 测试模式: 显示会替换哪些 UPX 特征，不修改文件。"
    },

    {
      "label": "📊 证书克隆 / Stage: clone PE signature only",
      "type": "shell",
      "command": "osslsigncode",
      "args": [
        "add-signature",
        "-in", "${input:cloneSource}",
        "-out", "${workspaceFolder}/release/fg-qimen-signed.exe"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "📊 仅证书克隆。从合法 PE 克隆签名到 fg-qimen-signed.exe。仅限授权测试。"
    },

    /* ═══════════════════════════════════════════════════════════
       🔬 一键对比 / Compare All Layers
       构建三层产物并对比体积
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "🔬 对比 三层构建+体积对比 / Compare: build all 3 layers + size",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "scripts/compare-layers.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "🔬 一键构建三层产物并对比体积: 原生 → 混淆 → 全流程。输出 release/ 下各产物大小对比表。"
    },

    /* ═══════════════════════════════════════════════════════════
        测试 / Test
       ═══════════════════════════════════════════════════════════ */

    {
      "label": " 测试 全部(静默)/ Test: all (quiet)",
      "type": "shell",
      "command": "go",
      "args": ["test", "${input:goPackage}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "跑全模块的 go test(默认 ./...)。"
    },

    {
      "label": " 测试 详细输出 / Test: verbose",
      "type": "shell",
      "command": "go",
      "args": ["test", "-v", "${input:goPackage}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go test -v — 完整 t.Logf / t.Run 输出。"
    },

    {
      "label": " 测试 数据竞争检测 / Test: race detector",
      "type": "shell",
      "command": "go",
      "args": ["test", "-race", "${input:goPackage}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go test -race (Windows+CGO=0 不支持，这是项目设计使然)。"
    },

    {
      "label": " 测试 名字过滤 / Test: filtered (run regex)",
      "type": "shell",
      "command": "go",
      "args": ["test", "-v", "-run", "${input:testFilter}", "${input:goPackage}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "按名字过滤(如 ^TestDispatcher$)。"
    },

    {
      "label": "🧪 测试 覆盖率 / Test: coverage",
      "type": "shell",
      "command": "go",
      "args": ["test", "-coverprofile=coverage.out", "-covermode=atomic", "${input:goPackage}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "生成 coverage.out 原子模式覆盖率文件。"
    },

    /* ═══════════════════════════════════════════════════════════
       ️ 质量 / Quality
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "⚙️ 格式化 go fmt / Fmt: go fmt ./...",
      "type": "shell",
      "command": "go",
      "args": ["fmt", "./..."],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": { "kind": "build", "isDefault": false },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "detail": "对所有 Go 文件执行 gofmt。"
    },

    {
      "label": "⚙️ 静态检查 vet / Vet: go vet ./...",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go vet ./... 静态检查。"
    },

    {
      "label": "⚙️ 全面体检 fmt+vet+test / Check: fmt + vet + test",
      "type": "shell",
      "command": "just",
      "args": ["check"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "等同于 just check — CI 闸门，fmt + vet + test 三合一。"
    },

    {
      "label": "⚙️ 依赖 tidy / Deps: tidy",
      "type": "shell",
      "command": "go",
      "args": ["mod", "tidy"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go mod tidy — 钉住间接依赖。"
    },

    {
      "label": "⚙️ 依赖 下载+校验 / Deps: download + verify",
      "type": "shell",
      "command": "just",
      "args": ["deps"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "just deps — 下载模块缓存并校验校验和。"
    },

    /* ═══════════════════════════════════════════════════════════
       🚀 运行 / Run
       ══════════════════════════════════════════════════════════ */

    {
      "label": "🚀 运行 go run .(带参)/ Run: go run . (with args)",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "${input:runArgs}"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go run . — 进程内运行(不产出 release/ 制品)。"
    },

    {
      "label": " 运行 已构建的二进制 / Run: built binary",
      "type": "shell",
      "command": "just",
      "args": ["run"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "just run — 依赖 just build; 用 justfile 默认参数跑 release/fg-qimen。"
    },

    {
      "label": " 运行 查看版本 / Run: version subcommand",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "version"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "打印 Cobra version 子命令的输出，验证嵌入的版本字符串。"
    },

    {
      "label": "🚀 运行 项目列表 / Run: projects list",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "projects", "list"],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "列出 bbolt 工作区(对应仓库根的 runs/ 目录)。"
    },

    /* ═══════════════════════════════════════════════════════════
       📦 发布辅助 / Release Helpers
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "📦 发布 生成 SHA256SUMS / Release: sha256sums",
      "type": "shell",
      "command": "just",
      "args": ["sha256sums"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "为 release/ 下所有产物生成 SHA256SUMS(在 just all 之后跑)。"
    },

    /* ═══════════════════════════════════════════════════════════
        清理 / Clean
       ═══════════════════════════════════════════════════════════ */

    {
      "label": " 清理 构建产物 / Clean: build artifacts",
      "type": "shell",
      "command": "just",
      "args": ["clean-build"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "detail": "删 release/fg-qimen(保留 release/ 目录)。"
    },

    {
      "label": " 清理 全部 release+runs+test / Clean: all",
      "type": "shell",
      "command": "just",
      "args": ["clean"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "激进清理: release/ + runs/ + test/ + 构建产物。"
    },

    {
      "label": "🧹 清理 仅扫描产物 / Clean: scan runs only",
      "type": "shell",
      "command": "just",
      "args": ["clean-runs"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "detail": "删 runs/(即扫即走 + project 模式输出)。"
    },

    /* ═══════════════════════════════════════════════════════════
       ℹ️ 信息 / Info
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "ℹ️ 信息 Go 模块 / Info: go module",
      "type": "shell",
      "command": "just",
      "args": ["modinfo"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "go list -m -json — 模块信息。"
    },

    {
      "label": "ℹ️ 信息 代码行数 / Info: source line counts",
      "type": "shell",
      "command": "just",
      "args": ["loc"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "统计 Go 源代码行数(排除 release/)。"
    },

    {
      "label": "ℹ️ 信息 justfile 配方清单 / Info: justfile recipes",
      "type": "shell",
      "command": "just",
      "args": ["--list"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "detail": "列出 justfile 所有配方。"
    },

    /* ═══════════════════════════════════════════════════════════
        调试 / Debug (launch.json preLaunchTask)
       ═══════════════════════════════════════════════════════════ */

    {
      "label": "🐞 调试 构建调试版二进制 / Build: debug (no inlining)",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-gcflags=all=-N -l",
        "-ldflags=-s -w -buildid= -X github.com/LCUstinian/FG-QiMen/internal/version.Value=0.2.0",
        "-trimpath", "-buildvcs=false",
        "-o", "${workspaceFolder}/release/fg-qimen-debug.exe",
        "."
      ],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "isBackground": false,
      "presentation": { "reveal": "silent", "panel": "shared" },
      "detail": "pre-debug 构建: 产出 release/fg-qimen-debug.exe，关闭优化与内联(-N -l)。作为 launch.json 的 preLaunchTask。"
    },

    {
      "label": " 调试 构建+启动 dlv / Build: debug + run dlv",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-gcflags=all=-N -l",
        "-ldflags=-s -w -buildid= -X github.com/LCUstinian/FG-QiMen/internal/version.Value=0.2.0",
        "-trimpath", "-buildvcs=false",
        "-o", "${workspaceFolder}/release/fg-qimen-debug.exe",
        "."
      ],
      "options": { "cwd": "${workspaceFolder}", "env": { "CGO_ENABLED": "0" } },
      "problemMatcher": ["$go"],
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "detail": "构建调试版二进制后立刻用 dlv 启动。"
    }
  ]
}